FROM ubuntu:24.04@sha256:c4a8d5503dfb2a3eb8ab5f807da5bc69a85730fb49b5cfca2330194ebcc41c7b

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gpg \
    dnsutils \
    whois \
    openssl \
    build-essential \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
