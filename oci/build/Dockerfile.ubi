ARG BASE_IMAGE=redhat/ubi9:latest@sha256:38952545b5a9ddf145152f37b0da702d7d75fac1ddc52c5e14b03c7a77c51586
FROM ${BASE_IMAGE}

RUN dnf update -y && \
    dnf install -y --allowerasing \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg2 \
    bind-utils \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
