ARG BASE_IMAGE=redhat/ubi9:latest@sha256:1b99266db480e8aa6dfda6900697a07ec99334095b4f87d1687edfc06c965132
FROM ${BASE_IMAGE}

RUN dnf update -y && \
    dnf install -y --allowerasing \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg2 \
    bind-utils \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
