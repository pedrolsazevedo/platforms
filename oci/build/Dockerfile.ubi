ARG BASE_IMAGE=redhat/ubi9:latest@sha256:fd3612ebe7968002122fb8c41df2cf9bd3f9916c573f7248113cdec1d6f4c245
FROM ${BASE_IMAGE}

RUN dnf update -y && \
    dnf install -y --allowerasing \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg2 \
    bind-utils \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
