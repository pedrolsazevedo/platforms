FROM opensuse/tumbleweed:latest@sha256:56a957fd0c4c478e7b21aa9a117d097f06609f77c22ac12ec8742be5cddd0537

RUN zypper refresh && zypper update -y && \
    zypper install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gpg2 \
    bind-utils \
    whois \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
