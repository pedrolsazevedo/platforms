FROM opensuse/tumbleweed:latest@sha256:f5e25e564dc0ffabeea50af67ac51cf487b592f1af931fa693037c44c447f5f8

RUN zypper refresh && zypper update -y && \
    zypper install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gpg2 \
    bind-utils \
    whois \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
