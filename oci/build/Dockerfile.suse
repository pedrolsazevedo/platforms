FROM opensuse/tumbleweed:latest@sha256:e5b87768f7cf4b210f4c979f747e859f9aef2317997bd8a06d98fabc523dd8ca

RUN zypper refresh && zypper update -y && \
    zypper install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gpg2 \
    bind-utils \
    whois \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
